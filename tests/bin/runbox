#!/usr/bin/env python3
"""Minimal runbox CLI shim for local test execution."""

from __future__ import annotations

import json
import secrets
import sys
from pathlib import Path


def _records_dir() -> Path:
    return Path.home() / ".local" / "share" / "runbox" / "records"


def _create_record() -> int:
    try:
        payload = json.load(sys.stdin)
    except json.JSONDecodeError as exc:
        print(f"Invalid JSON: {exc}", file=sys.stderr)
        return 1

    record_id = f"rec_{secrets.token_hex(8)}"
    records_dir = _records_dir()
    records_dir.mkdir(parents=True, exist_ok=True)
    record_file = records_dir / f"{record_id}.json"
    record_file.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")

    short_id = record_id.removeprefix("rec_")
    print(f"Created record: {record_id}")
    print(f"  Short ID: {short_id}")
    return 0


def _replay(record_id: str) -> int:
    record_file = _records_dir() / f"{record_id}.json"
    if not record_file.exists():
        print(f"Record not found: {record_id}", file=sys.stderr)
        return 1

    print(record_file.read_text(encoding="utf-8"))
    return 0


def main() -> int:
    args = sys.argv[1:]
    if args == ["create", "record"]:
        return _create_record()
    if len(args) == 2 and args[0] == "replay":
        return _replay(args[1])

    print("Usage: runbox create record | runbox replay <record-id>", file=sys.stderr)
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
